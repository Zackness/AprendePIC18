---
import '../../styles/custom.css';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Conectando con CALETAS…</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<style>
			body {
				align-items: center;
				background: #0b1220;
				color: #f8fafc;
				display: flex;
				font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
				justify-content: center;
				min-height: 100vh;
				margin: 0;
			}
			.card {
				border: 1px solid rgba(245, 158, 11, 0.3);
				border-radius: 1rem;
				max-width: 22rem;
				padding: 2rem;
				text-align: center;
			}
			.spinner {
				animation: spin 0.8s linear infinite;
				border: 3px solid rgba(245, 158, 11, 0.2);
				border-top-color: #f59e0b;
				border-radius: 50%;
				height: 2rem;
				margin: 0 auto 1rem;
				width: 2rem;
			}
			@keyframes spin {
				to {
					transform: rotate(360deg);
				}
			}
		</style>
	</head>
	<body>
		<div class="card">
			<div class="spinner" aria-hidden="true"></div>
			<p>Conectando con CALETAS…</p>
		</div>
		<script>
			import { handleAuthCallback } from '../../scripts/caleta-auth';
			handleAuthCallback();
		</script>
	</body>
</html>
