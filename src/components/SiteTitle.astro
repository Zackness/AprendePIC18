---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title">
	<svg class="site-title__mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
		<rect x="4" y="4" width="24" height="24" rx="5" fill="#14213d" stroke="#f59e0b" stroke-width="1.5"></rect>
		<rect x="8" y="8" width="16" height="16" rx="2" fill="#0f172a" stroke="rgba(34,211,238,0.35)" stroke-width="1"></rect>
		<text x="16" y="19" text-anchor="middle" fill="#fbbf24" font-family="JetBrains Mono, monospace" font-size="8" font-weight="700">18</text>
		<circle cx="4" cy="10" r="1.2" fill="#22d3ee"></circle>
		<circle cx="4" cy="16" r="1.2" fill="#22d3ee"></circle>
		<circle cx="4" cy="22" r="1.2" fill="#22d3ee"></circle>
		<circle cx="28" cy="10" r="1.2" fill="#f59e0b"></circle>
		<circle cx="28" cy="16" r="1.2" fill="#f59e0b"></circle>
		<circle cx="28" cy="22" r="1.2" fill="#f59e0b"></circle>
		<circle cx="10" cy="4" r="1.2" fill="#f59e0b"></circle>
		<circle cx="16" cy="4" r="1.2" fill="#f59e0b"></circle>
		<circle cx="22" cy="4" r="1.2" fill="#f59e0b"></circle>
		<circle cx="10" cy="28" r="1.2" fill="#22d3ee"></circle>
		<circle cx="16" cy="28" r="1.2" fill="#22d3ee"></circle>
		<circle cx="22" cy="28" r="1.2" fill="#22d3ee"></circle>
	</svg>
	<span class="site-title__brand">
		Aprende<span class="site-title__accent">PIC18</span>
	</span>
	<span class="site-title__badge">CALETAS</span>
</a>
