---
import config from 'virtual:starlight/user-config';
import CaletasIcon from './icons/CaletasIcon.astro';
import StartupVenIcon from './icons/StartupVenIcon.astro';

const links = config.social || [];

/** Paths de iconos Starlight (github, instagram, tiktok, etc.) */
const ICON_PATHS: Record<string, string> = {
	github:
		'M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z',
	instagram:
		'M17.3 5.5a1.2 1.2 0 1 0 1.2 1.2 1.2 1.2 0 0 0-1.2-1.2ZM22 7.9a7.6 7.6 0 0 0-.4-2.5 5 5 0 0 0-1.2-1.7 4.7 4.7 0 0 0-1.8-1.2 7.3 7.3 0 0 0-2.4-.4L12 2H7.9a7.3 7.3 0 0 0-2.5.5 4.8 4.8 0 0 0-1.7 1.2 4.7 4.7 0 0 0-1.2 1.8 7.3 7.3 0 0 0-.4 2.4L2 12v4.1a7.3 7.3 0 0 0 .5 2.4 4.7 4.7 0 0 0 1.2 1.8 4.8 4.8 0 0 0 1.8 1.2 7.3 7.3 0 0 0 2.4.4l4.1.1h4.1a7.3 7.3 0 0 0 2.4-.5 4.7 4.7 0 0 0 1.8-1.2 4.8 4.8 0 0 0 1.2-1.7 7.6 7.6 0 0 0 .4-2.5L22 12V7.9ZM20.1 16a5.6 5.6 0 0 1-.3 1.9A3 3 0 0 1 19 19a3.2 3.2 0 0 1-1.1.8 5.6 5.6 0 0 1-1.9.3H8a5.7 5.7 0 0 1-1.9-.3A3.3 3.3 0 0 1 5 19a3 3 0 0 1-.7-1.1 5.5 5.5 0 0 1-.4-1.9l-.1-4V8a5.5 5.5 0 0 1 .4-1.9A3 3 0 0 1 5 5a3.1 3.1 0 0 1 1.1-.8A5.7 5.7 0 0 1 8 3.9l4-.1h4a5.6 5.6 0 0 1 1.9.4A3 3 0 0 1 19 5a3 3 0 0 1 .7 1.1A5.6 5.6 0 0 1 20 8l.1 4v4ZM12 6.9a5.1 5.1 0 1 0 5.1 5.1A5.1 5.1 0 0 0 12 6.9Zm0 8.4a3.3 3.3 0 1 1 3.3-3.3 3.3 3.3 0 0 1-3.3 3.3Z',
	tiktok:
		'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z',
};
---

{
	links.length > 0 && (
		<>
			{links.map(({ label, href, icon }) => (
				<a {href} rel="me" class="social-link sl-flex" title={label}>
					<span class="sr-only">{label}</span>
					{label === 'CALETAS' ? (
						<CaletasIcon />
					) : label === 'StartupVen' ? (
						<StartupVenIcon />
					) : ICON_PATHS[icon] ? (
						<svg class="social-link__icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d={ICON_PATHS[icon]} />
						</svg>
					) : (
						<svg class="social-link__icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M15.5 2.25a6.5 6.5 0 0 0-6.5 6.5v3.25H7.5a1 1 0 0 0-1 1v4.5a1 1 0 0 0 1 1h1.5V21a1 1 0 0 0 1 1h4.5a1 1 0 0 0 1-1v-3.25h1.5a1 1 0 0 0 1-1v-4.5a1 1 0 0 0-1-1h-1.5V8.75a4 4 0 0 1 4-4h.5a1 1 0 0 0 1-1V3.25a1 1 0 0 0-1-1h-.5A6.5 6.5 0 0 0 15.5 2.25Z" />
						</svg>
					)}
				</a>
			))}
		</>
	)
}

<style>
	@layer starlight.core {
		.social-link {
			align-items: center;
			color: var(--sl-color-text-accent);
			display: inline-flex;
			justify-content: center;
			margin: -0.5em;
			padding: 0.5em;
			transition: transform 0.15s ease, opacity 0.15s ease;
		}

		.social-link:hover {
			color: var(--sl-color-white);
			transform: translateY(-1px);
		}

		.social-link__icon,
		.social-link :global(.brand-icon) {
			display: block;
			height: 1.125rem;
			width: 1.125rem;
		}
	}
</style>
