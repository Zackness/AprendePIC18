---
import type { PageQuiz } from '../data/quizzes';
import { isQuizAuthRequired } from '../data/quizzes';
import type { ExamAuthMode } from '../data/lab-tiered-quizzes';
import CaletasIcon from './icons/CaletasIcon.astro';

interface Props {
	quiz: PageQuiz;
	locale?: 'es' | 'en';
	authMode?: ExamAuthMode;
	compact?: boolean;
}

const { quiz, locale = 'es', authMode: authModeProp, compact = false } = Astro.props;
const isEn = locale === 'en';
const authMode: ExamAuthMode =
	authModeProp ?? (isQuizAuthRequired(quiz.slug) ? 'login' : 'none');
const title = isEn ? quiz.titleEn : quiz.titleEs;
const questions = quiz.questions.map((q) => ({
	id: q.id,
	question: isEn ? q.questionEn : q.questionEs,
	options: isEn ? q.optionsEn : q.optionsEs,
	correctIndex: q.correctIndex,
	explanation: isEn ? q.explanationEn : q.explanationEs,
}));
const quizJson = JSON.stringify({ slug: quiz.slug, questions });
---

<section
	class:list={['interactive-quiz', compact && 'interactive-quiz--compact']}
	data-interactive-quiz
	data-quiz-slug={quiz.slug}
	data-auth-mode={authMode}
	data-quiz-json={quizJson}
	aria-labelledby={compact ? undefined : `quiz-title-${quiz.slug.replace(/\//g, '-')}`}
>
	{
		!compact && (
			<header class="interactive-quiz__header">
				<span class="interactive-quiz__badge">
					{isEn ? 'Interactive exam' : 'Examen interactivo'}
				</span>
				<h2 class="interactive-quiz__title" id={`quiz-title-${quiz.slug.replace(/\//g, '-')}`}>
					{title}
				</h2>
				{
					quiz.sourceDoc && (
						<p class="interactive-quiz__source">
							{isEn ? 'Based on' : 'Basado en'}: {quiz.sourceDoc}
						</p>
					)
				}
			</header>
		)
	}

	<div class="interactive-quiz__body">
		<div class="interactive-quiz__content-wrap">
			<div class="interactive-quiz__progress-wrap">
				<div class="interactive-quiz__progress-bar">
					<div class="interactive-quiz__progress-fill" data-quiz-progress-fill style="width: 0%"></div>
				</div>
				<p class="interactive-quiz__progress-text" data-quiz-progress-text>
					{isEn ? '0 of 0 answered' : '0 de 0 respondidas'}
				</p>
			</div>

			<form class="interactive-quiz__form" data-quiz-form novalidate>
				{
					questions.map((q, qi) => (
						<fieldset class="interactive-quiz__question" data-question-index={qi}>
							<legend class="interactive-quiz__question-text">{q.question}</legend>
							<div class="interactive-quiz__options">
								{q.options.map((opt, oi) => (
									<label class="interactive-quiz__option">
										<input
											type="radio"
											name={`q-${quiz.slug}-${q.id}`}
											value={oi}
											data-option-index={oi}
											data-original-index={oi}
										/>
										<span class="interactive-quiz__option-box" aria-hidden="true" />
										<span class="interactive-quiz__option-text">{opt}</span>
									</label>
								))}
							</div>
							<p class="interactive-quiz__feedback" data-feedback hidden />
						</fieldset>
					))
				}

				<div class="interactive-quiz__actions">
					<button type="submit" class="interactive-quiz__submit">
						{isEn ? 'Check answers' : 'Comprobar respuestas'}
					</button>
					<p class="interactive-quiz__result" data-quiz-result hidden />
				</div>
			</form>
		</div>

		{
			authMode !== 'none' && (
				<div
					class="interactive-quiz__auth-overlay"
					data-quiz-auth-gate
					hidden
					role="dialog"
					aria-modal="true"
					aria-labelledby={`quiz-auth-title-${quiz.slug.replace(/\//g, '-')}`}
				>
					<div class="interactive-quiz__auth-modal">
						<div class="interactive-quiz__auth-lock" aria-hidden="true">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none">
								<rect
									x="5"
									y="11"
									width="14"
									height="10"
									rx="2"
									stroke="currentColor"
									stroke-width="1.75"
								/>
								<path
									d="M8 11V8a4 4 0 0 1 8 0v3"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
								/>
							</svg>
						</div>
						<h3
							class="interactive-quiz__auth-title"
							id={`quiz-auth-title-${quiz.slug.replace(/\//g, '-')}`}
							data-quiz-auth-title
						>
							{isEn ? 'Sign in' : 'Inicia sesión'}
						</h3>
						<p class="interactive-quiz__auth-subtitle" data-quiz-auth-subtitle>
							{isEn
								? 'Sign in with CALETAS to submit this exam and save your score.'
								: 'Inicia sesion en CALETAS para presentar este examen y guardar tu nota.'}
						</p>
						<div class="interactive-quiz__auth-actions">
							<a href="#" class="interactive-quiz__auth-btn interactive-quiz__auth-btn--caleta" data-caleta-login>
								<CaletasIcon class="interactive-quiz__auth-btn-icon" />
								<span>{isEn ? 'Sign in with CALETAS' : 'Iniciar sesión con CALETAS'}</span>
							</a>
							<a
								href="https://caleta.top/suscripcion"
								class="interactive-quiz__auth-btn interactive-quiz__auth-btn--secondary"
								data-quiz-plans-link
								target="_blank"
								rel="noopener noreferrer"
								hidden
							>
								{isEn ? 'View CALETAS plans' : 'Ver planes CALETAS'}
							</a>
						</div>
					</div>
				</div>
			)
		}
	</div>

	<div class="interactive-quiz__login-hint" data-quiz-login-hint hidden>
		<p>
			{isEn
				? 'Sign in with CALETAS to sync this result across devices.'
				: 'Inicia sesion en CALETAS para sincronizar este resultado entre dispositivos.'}
		</p>
		<a href="#" class="interactive-quiz__login-btn" data-caleta-login>
			{isEn ? 'Sign in with CALETAS' : 'Iniciar sesion en CALETAS'}
		</a>
	</div>
</section>

<script>
	import { initCaletaAuth, saveQuizResult, getQuizResult, isLoggedIn } from '../scripts/caleta-auth';
	import { fetchDownloadAccess, subscriptionPlansUrl } from '../scripts/caleta-downloads';

	function shuffleQuizOptions(fieldset: Element) {
		const container = fieldset.querySelector('.interactive-quiz__options');
		if (!container) return;

		const labels = Array.from(
			container.querySelectorAll('label.interactive-quiz__option'),
		);
		for (let i = labels.length - 1; i > 0; i -= 1) {
			const j = Math.floor(Math.random() * (i + 1));
			[labels[i], labels[j]] = [labels[j], labels[i]];
		}
		labels.forEach((label, displayIndex) => {
			container.appendChild(label);
			const input = label.querySelector('input[type="radio"]');
			if (input instanceof HTMLInputElement) {
				input.dataset.optionIndex = String(displayIndex);
			}
		});
	}

	function getSelectedOriginalIndex(fieldset: Element): number {
		const selected = fieldset.querySelector(
			'input[type="radio"]:checked',
		) as HTMLInputElement | null;
		if (!selected) return -1;
		return Number(selected.dataset.originalIndex ?? selected.dataset.optionIndex ?? -1);
	}

	async function setQuizAuthState(root: Element) {
		const authMode = root.getAttribute('data-auth-mode') || 'none';
		const gate = root.querySelector('[data-quiz-auth-gate]');
		const form = root.querySelector('[data-quiz-form]');
		const submit = root.querySelector('.interactive-quiz__submit');
		const authTitle = root.querySelector('[data-quiz-auth-title]');
		const authSubtitle = root.querySelector('[data-quiz-auth-subtitle]');
		const plansLink = root.querySelector('[data-quiz-plans-link]');
		const isEn = document.documentElement.lang?.startsWith('en');

		if (authMode === 'none') {
			root.classList.remove('interactive-quiz--locked');
			if (gate) gate.hidden = true;
			return;
		}

		let locked = false;

		if (authMode === 'login') {
			locked = !isLoggedIn();
		} else if (authMode === 'subscription') {
			const access = await fetchDownloadAccess().catch(() => ({
				authenticated: isLoggedIn(),
				canDownload: false,
				reason: 'no_subscription' as const,
			}));
			locked = !access.canDownload;
			if (plansLink instanceof HTMLAnchorElement) {
				plansLink.href = subscriptionPlansUrl();
				plansLink.hidden = access.canDownload;
			}
			if (authTitle && authSubtitle) {
				if (!access.authenticated) {
					authTitle.textContent = isEn ? 'Sign in' : 'Inicia sesión';
					authSubtitle.textContent = isEn
						? 'Sign in with CALETAS to submit this exam.'
						: 'Inicia sesion en CALETAS para presentar este examen.';
				} else {
					authTitle.textContent = isEn
						? 'Subscription required'
						: 'Suscripcion requerida';
					authSubtitle.textContent = isEn
						? 'An active CALETAS plan is required for this exam level.'
						: 'Se requiere un plan activo en CALETAS para este nivel de examen.';
				}
			}
		} else {
			locked = !isLoggedIn();
		}

		root.classList.toggle('interactive-quiz--locked', locked);
		if (gate) gate.hidden = !locked;
		if (form instanceof HTMLFormElement) {
			form.querySelectorAll('input, button').forEach((el) => {
				if (el instanceof HTMLInputElement || el instanceof HTMLButtonElement) {
					el.disabled = locked;
				}
			});
		}
		if (submit instanceof HTMLButtonElement && locked) {
			submit.disabled = true;
		}
	}

	function initInteractiveQuizzes() {
		initCaletaAuth();

		document.querySelectorAll('[data-interactive-quiz]').forEach((root) => {
			if (root.getAttribute('data-quiz-init') === '1') return;
			root.setAttribute('data-quiz-init', '1');

			const slug = root.getAttribute('data-quiz-slug') || '';
			const authMode = root.getAttribute('data-auth-mode') || 'none';
			const json = root.getAttribute('data-quiz-json') || '{}';
			const isEn = document.documentElement.lang?.startsWith('en');
			let quizData;
			try {
				quizData = JSON.parse(json);
			} catch {
				return;
			}

			const form = root.querySelector('[data-quiz-form]');
			const resultEl = root.querySelector('[data-quiz-result]');
			const loginHint = root.querySelector('[data-quiz-login-hint]');
			const progressFill = root.querySelector('[data-quiz-progress-fill]');
			const progressText = root.querySelector('[data-quiz-progress-text]');
			const fieldsets = root.querySelectorAll('[data-question-index]');
			const total = fieldsets.length;

			fieldsets.forEach((fs) => shuffleQuizOptions(fs));

			setQuizAuthState(root);
			window.addEventListener('aprende-auth-change', () => {
				setQuizAuthState(root);
				restoreSavedQuizState();
			});
			window.addEventListener('aprende-progress-sync', restoreSavedQuizState);
			initCaletaAuth();

			function restoreSavedQuizState() {
				const saved = getQuizResult(slug);
				if (!saved) return;

				const hasAnswers =
					Array.isArray(saved.answers) && saved.answers.length === total;

				if (hasAnswers) {
					fieldsets.forEach((fs, qi) => {
						const q = quizData.questions[qi];
						const chosen = saved.answers![qi];
						const feedback = fs.querySelector('[data-feedback]');
						fs.classList.remove(
							'interactive-quiz__question--correct',
							'interactive-quiz__question--wrong',
						);

						if (!q || chosen < 0) return;

						const input = fs.querySelector(
							`input[data-original-index="${chosen}"]`,
						) as HTMLInputElement | null;
						if (input) input.checked = true;

						const isCorrect = chosen === q.correctIndex;
						fs.classList.add(
							isCorrect
								? 'interactive-quiz__question--correct'
								: 'interactive-quiz__question--wrong',
						);

						if (feedback) {
							feedback.hidden = false;
							if (isCorrect) {
								feedback.textContent = isEn ? 'Correct!' : 'Correcto!';
							} else if (q.explanation) {
								feedback.textContent = q.explanation;
							} else {
								feedback.textContent = isEn ? 'Incorrect.' : 'Incorrecto.';
							}
						}
					});
				}

				if (resultEl) {
					resultEl.hidden = false;
					resultEl.className = `interactive-quiz__result ${saved.passed ? 'interactive-quiz__result--pass' : 'interactive-quiz__result--fail'}`;
					const when = saved.at
						? isEn
							? ` — Last attempt: ${new Date(saved.at).toLocaleString()}`
							: ` — Ultimo intento: ${new Date(saved.at).toLocaleString()}`
						: '';
					resultEl.textContent = isEn
						? `${saved.correct}/${saved.total} correct (${saved.score}%)${saved.passed ? ' — Passed!' : ' — Review and try again.'}${when}`
						: `${saved.correct}/${saved.total} correctas (${saved.score}%)${saved.passed ? ' — ¡Aprobado!' : ' — Repasa e intenta de nuevo.'}${when}`;
				}

				root.classList.toggle('interactive-quiz--passed', saved.passed);
				updateAnsweredProgress();
			}

			function updateAnsweredProgress() {
				let answered = 0;
				fieldsets.forEach((fs) => {
					if (fs.querySelector('input[type="radio"]:checked')) answered += 1;
				});
				const pct = total ? Math.round((answered / total) * 100) : 0;
				if (progressFill) progressFill.style.width = `${pct}%`;
				if (progressText) {
					progressText.textContent = isEn
						? `${answered} of ${total} answered`
						: `${answered} de ${total} respondidas`;
				}
			}

			fieldsets.forEach((fs) => {
				fs.querySelectorAll('input[type="radio"]').forEach((input) => {
					input.addEventListener('change', updateAnsweredProgress);
				});
			});

			updateAnsweredProgress();
			restoreSavedQuizState();

			form?.addEventListener('submit', async (e) => {
				e.preventDefault();

				if (authMode !== 'none') {
					if (authMode === 'subscription') {
						const access = await fetchDownloadAccess().catch(() => null);
						if (!access?.canDownload) {
							await setQuizAuthState(root);
							if (resultEl) {
								resultEl.hidden = false;
								resultEl.className = 'interactive-quiz__result interactive-quiz__result--warn';
								resultEl.textContent = isEn
									? 'An active CALETAS subscription is required.'
									: 'Se requiere suscripcion activa en CALETAS.';
							}
							return;
						}
					} else if (!isLoggedIn()) {
						await setQuizAuthState(root);
						if (resultEl) {
							resultEl.hidden = false;
							resultEl.className = 'interactive-quiz__result interactive-quiz__result--warn';
							resultEl.textContent = isEn
								? 'Sign in with CALETAS to submit this exam.'
								: 'Inicia sesion en CALETAS para presentar este examen.';
						}
						return;
					}
				}

				let correct = 0;
				let allAnswered = true;
				const answers: number[] = [];

				fieldsets.forEach((fs, qi) => {
					const q = quizData.questions[qi];
					const feedback = fs.querySelector('[data-feedback]');
					fs.classList.remove(
						'interactive-quiz__question--correct',
						'interactive-quiz__question--wrong',
					);

					const chosen = getSelectedOriginalIndex(fs);
					if (chosen < 0 || !q) {
						allAnswered = false;
						answers.push(-1);
						return;
					}

					answers.push(chosen);
					const isCorrect = chosen === q.correctIndex;
					if (isCorrect) correct += 1;

					fs.classList.add(
						isCorrect
							? 'interactive-quiz__question--correct'
							: 'interactive-quiz__question--wrong',
					);

					if (feedback) {
						feedback.hidden = false;
						if (isCorrect) {
							feedback.textContent = isEn ? 'Correct!' : 'Correcto!';
						} else if (q.explanation) {
							feedback.textContent = q.explanation;
						} else {
							feedback.textContent = isEn ? 'Incorrect.' : 'Incorrecto.';
						}
					}
				});

				if (!allAnswered) {
					if (resultEl) {
						resultEl.hidden = false;
						resultEl.className = 'interactive-quiz__result interactive-quiz__result--warn';
						resultEl.textContent = isEn
							? 'Answer all questions before checking.'
							: 'Responde todas las preguntas antes de comprobar.';
					}
					return;
				}

				const score = Math.round((correct / total) * 100);
				const passed = score >= 70;

				if (resultEl) {
					resultEl.hidden = false;
					resultEl.className = `interactive-quiz__result ${passed ? 'interactive-quiz__result--pass' : 'interactive-quiz__result--fail'}`;
					resultEl.textContent = isEn
						? `${correct}/${total} correct (${score}%)${passed ? ' — Passed!' : ' — Review and try again.'}`
						: `${correct}/${total} correctas (${score}%)${passed ? ' — ¡Aprobado!' : ' — Repasa e intenta de nuevo.'}`;
				}

				root.classList.toggle('interactive-quiz--passed', passed);

				saveQuizResult(slug, { score, passed, correct, total, answers });

				if (authMode === 'none' && !isLoggedIn() && loginHint) {
					loginHint.hidden = false;
				}

				window.dispatchEvent(
					new CustomEvent('aprende-quiz-complete', {
						detail: { slug, score, passed },
					}),
				);
			});
		});
	}

	initInteractiveQuizzes();
	document.addEventListener('astro:page-load', initInteractiveQuizzes);
</script>
