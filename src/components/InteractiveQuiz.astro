---
import type { PageQuiz } from '../data/quizzes';
import { isQuizAuthRequired } from '../data/quizzes';

interface Props {
	quiz: PageQuiz;
	locale?: 'es' | 'en';
}

const { quiz, locale = 'es' } = Astro.props;
const isEn = locale === 'en';
const authRequired = isQuizAuthRequired(quiz.slug);
const title = isEn ? quiz.titleEn : quiz.titleEs;
const questions = quiz.questions.map((q) => ({
	id: q.id,
	question: isEn ? q.questionEn : q.questionEs,
	options: isEn ? q.optionsEn : q.optionsEs,
	correctIndex: q.correctIndex,
	explanation: isEn ? q.explanationEn : q.explanationEs,
}));
const quizJson = JSON.stringify({ slug: quiz.slug, questions });
---

<section
	class="interactive-quiz"
	data-interactive-quiz
	data-quiz-slug={quiz.slug}
	data-auth-required={authRequired ? '1' : '0'}
	data-quiz-json={quizJson}
	aria-labelledby={`quiz-title-${quiz.slug.replace(/\//g, '-')}`}
>
	<header class="interactive-quiz__header">
		<span class="interactive-quiz__badge">
			{isEn ? 'Interactive exam' : 'Examen interactivo'}
		</span>
		<h2 class="interactive-quiz__title" id={`quiz-title-${quiz.slug.replace(/\//g, '-')}`}>
			{title}
		</h2>
		{
			quiz.sourceDoc && (
				<p class="interactive-quiz__source">
					{isEn ? 'Based on' : 'Basado en'}: {quiz.sourceDoc}
				</p>
			)
		}
	</header>

	<div class="interactive-quiz__body">
		<div class="interactive-quiz__content-wrap">
			<div class="interactive-quiz__progress-wrap">
				<div class="interactive-quiz__progress-bar">
					<div class="interactive-quiz__progress-fill" data-quiz-progress-fill style="width: 0%"></div>
				</div>
				<p class="interactive-quiz__progress-text" data-quiz-progress-text>
					{isEn ? '0 of 0 answered' : '0 de 0 respondidas'}
				</p>
			</div>

			<form class="interactive-quiz__form" data-quiz-form novalidate>
				{
					questions.map((q, qi) => (
						<fieldset class="interactive-quiz__question" data-question-index={qi}>
							<legend class="interactive-quiz__question-text">{q.question}</legend>
							<div class="interactive-quiz__options">
								{q.options.map((opt, oi) => (
									<label class="interactive-quiz__option">
										<input
											type="radio"
											name={`q-${quiz.slug}-${q.id}`}
											value={oi}
											data-option-index={oi}
										/>
										<span class="interactive-quiz__option-box" aria-hidden="true" />
										<span class="interactive-quiz__option-text">{opt}</span>
									</label>
								))}
							</div>
							<p class="interactive-quiz__feedback" data-feedback hidden />
						</fieldset>
					))
				}

				<div class="interactive-quiz__actions">
					<button type="submit" class="interactive-quiz__submit">
						{isEn ? 'Check answers' : 'Comprobar respuestas'}
					</button>
					<p class="interactive-quiz__result" data-quiz-result hidden />
				</div>
			</form>
		</div>

		{
			authRequired && (
				<div
					class="interactive-quiz__auth-overlay"
					data-quiz-auth-gate
					role="dialog"
					aria-modal="true"
					aria-labelledby={`quiz-auth-title-${quiz.slug.replace(/\//g, '-')}`}
				>
					<div class="interactive-quiz__auth-modal">
						<div class="interactive-quiz__auth-lock" aria-hidden="true">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none">
								<rect
									x="5"
									y="11"
									width="14"
									height="10"
									rx="2"
									stroke="currentColor"
									stroke-width="1.75"
								/>
								<path
									d="M8 11V8a4 4 0 0 1 8 0v3"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
								/>
							</svg>
						</div>
						<h3
							class="interactive-quiz__auth-title"
							id={`quiz-auth-title-${quiz.slug.replace(/\//g, '-')}`}
						>
							{isEn ? 'Sign in' : 'Inicia sesión'}
						</h3>
						<p class="interactive-quiz__auth-subtitle">
							{isEn
								? 'To save your progress and unlock achievements'
								: 'Para guardar tu progreso y desbloquear logros'}
						</p>
						<div class="interactive-quiz__auth-actions">
							<a
								href="#"
								class="interactive-quiz__auth-btn interactive-quiz__auth-btn--google"
								data-caleta-login-social="google"
							>
								<svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
									<path
										fill="#4285F4"
										d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
									/>
									<path
										fill="#34A853"
										d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
									/>
									<path
										fill="#FBBC05"
										d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
									/>
									<path
										fill="#EA4335"
										d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
									/>
								</svg>
								<span>Google</span>
							</a>
							<a
								href="#"
								class="interactive-quiz__auth-btn interactive-quiz__auth-btn--github"
								data-caleta-login-social="github"
							>
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
								</svg>
								<span>GitHub</span>
							</a>
						</div>
					</div>
				</div>
			)
		}
	</div>

	<div class="interactive-quiz__login-hint" data-quiz-login-hint hidden>
		<p>
			{isEn
				? 'Sign in with CALETAS to sync this result across devices.'
				: 'Inicia sesion en CALETAS para sincronizar este resultado entre dispositivos.'}
		</p>
		<a href="#" class="interactive-quiz__login-btn" data-caleta-login>
			{isEn ? 'Sign in with CALETAS' : 'Iniciar sesion en CALETAS'}
		</a>
	</div>
</section>

<script>
	import { initCaletaAuth, saveQuizResult, isLoggedIn } from '../scripts/caleta-auth';

	function setQuizAuthState(root: Element) {
		const authRequired = root.getAttribute('data-auth-required') === '1';
		const loggedIn = isLoggedIn();
		const gate = root.querySelector('[data-quiz-auth-gate]');
		const form = root.querySelector('[data-quiz-form]');
		const submit = root.querySelector('.interactive-quiz__submit');
		const isEn = document.documentElement.lang?.startsWith('en');

		const locked = authRequired && !loggedIn;
		root.classList.toggle('interactive-quiz--locked', locked);

		if (gate) gate.hidden = !locked;
		if (form instanceof HTMLFormElement) {
			form.querySelectorAll('input, button').forEach((el) => {
				if (el instanceof HTMLInputElement || el instanceof HTMLButtonElement) {
					el.disabled = locked;
				}
			});
		}
		if (submit instanceof HTMLButtonElement && locked) {
			submit.disabled = true;
		}
	}

	function initInteractiveQuizzes() {
		initCaletaAuth();

		document.querySelectorAll('[data-interactive-quiz]').forEach((root) => {
			if (root.getAttribute('data-quiz-init') === '1') return;
			root.setAttribute('data-quiz-init', '1');

			const slug = root.getAttribute('data-quiz-slug') || '';
			const authRequired = root.getAttribute('data-auth-required') === '1';
			const json = root.getAttribute('data-quiz-json') || '{}';
			const isEn = document.documentElement.lang?.startsWith('en');
			let quizData;
			try {
				quizData = JSON.parse(json);
			} catch {
				return;
			}

			const form = root.querySelector('[data-quiz-form]');
			const resultEl = root.querySelector('[data-quiz-result]');
			const loginHint = root.querySelector('[data-quiz-login-hint]');
			const progressFill = root.querySelector('[data-quiz-progress-fill]');
			const progressText = root.querySelector('[data-quiz-progress-text]');
			const fieldsets = root.querySelectorAll('[data-question-index]');
			const total = fieldsets.length;

			setQuizAuthState(root);
			window.addEventListener('aprende-auth-change', () => setQuizAuthState(root));
			initCaletaAuth();

			function updateAnsweredProgress() {
				let answered = 0;
				fieldsets.forEach((fs) => {
					if (fs.querySelector('input[type="radio"]:checked')) answered += 1;
				});
				const pct = total ? Math.round((answered / total) * 100) : 0;
				if (progressFill) progressFill.style.width = `${pct}%`;
				if (progressText) {
					progressText.textContent = isEn
						? `${answered} of ${total} answered`
						: `${answered} de ${total} respondidas`;
				}
			}

			fieldsets.forEach((fs) => {
				fs.querySelectorAll('input[type="radio"]').forEach((input) => {
					input.addEventListener('change', updateAnsweredProgress);
				});
			});

			updateAnsweredProgress();

			form?.addEventListener('submit', (e) => {
				e.preventDefault();

				if (authRequired && !isLoggedIn()) {
					setQuizAuthState(root);
					if (resultEl) {
						resultEl.hidden = false;
						resultEl.className = 'interactive-quiz__result interactive-quiz__result--warn';
						resultEl.textContent = isEn
							? 'Sign in with CALETAS to submit this exam.'
							: 'Inicia sesion en CALETAS para presentar este examen.';
					}
					return;
				}

				let correct = 0;
				let allAnswered = true;

				fieldsets.forEach((fs, qi) => {
					const q = quizData.questions[qi];
					const selected = fs.querySelector('input[type="radio"]:checked');
					const feedback = fs.querySelector('[data-feedback]');
					fs.classList.remove(
						'interactive-quiz__question--correct',
						'interactive-quiz__question--wrong',
					);

					if (!selected || !q) {
						allAnswered = false;
						return;
					}

					const chosen = Number(selected.getAttribute('data-option-index'));
					const isCorrect = chosen === q.correctIndex;
					if (isCorrect) correct += 1;

					fs.classList.add(
						isCorrect
							? 'interactive-quiz__question--correct'
							: 'interactive-quiz__question--wrong',
					);

					if (feedback) {
						feedback.hidden = false;
						if (isCorrect) {
							feedback.textContent = isEn ? 'Correct!' : 'Correcto!';
						} else if (q.explanation) {
							feedback.textContent = q.explanation;
						} else {
							feedback.textContent = isEn ? 'Incorrect.' : 'Incorrecto.';
						}
					}
				});

				if (!allAnswered) {
					if (resultEl) {
						resultEl.hidden = false;
						resultEl.className = 'interactive-quiz__result interactive-quiz__result--warn';
						resultEl.textContent = isEn
							? 'Answer all questions before checking.'
							: 'Responde todas las preguntas antes de comprobar.';
					}
					return;
				}

				const score = Math.round((correct / total) * 100);
				const passed = score >= 70;

				if (resultEl) {
					resultEl.hidden = false;
					resultEl.className = `interactive-quiz__result ${passed ? 'interactive-quiz__result--pass' : 'interactive-quiz__result--fail'}`;
					resultEl.textContent = isEn
						? `${correct}/${total} correct (${score}%)${passed ? ' — Lesson passed!' : ' — Review the topic and try again.'}`
						: `${correct}/${total} correctas (${score}%)${passed ? ' — ¡Clase aprobada!' : ' — Repasa el tema e intenta de nuevo.'}`;
				}

				root.classList.toggle('interactive-quiz--passed', passed);

				saveQuizResult(slug, { score, passed, correct, total });

				if (!authRequired && !isLoggedIn() && loginHint) {
					loginHint.hidden = false;
				}

				window.dispatchEvent(
					new CustomEvent('aprende-quiz-complete', {
						detail: { slug, score, passed },
					}),
				);
			});
		});
	}

	initInteractiveQuizzes();
	document.addEventListener('astro:page-load', initInteractiveQuizzes);
</script>
