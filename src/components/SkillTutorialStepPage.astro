---
import {
	getSkillStepNav,
	skillSeriesHref,
	skillStepHref,
} from '../data/skill-tutorials';

interface Props {
	seriesId: string;
	stepId: string;
	locale?: 'es' | 'en';
}

const { seriesId, stepId, locale = 'es' } = Astro.props;
const isEn = locale === 'en';
const nav = getSkillStepNav(seriesId, stepId);

if (!nav) {
	throw new Error(`Skill tutorial step not found: ${seriesId}/${stepId}`);
}

const { series, step, index, total, prev, next } = nav;
const progressKey = `${seriesId}/${stepId}`;
const title = isEn ? step.titleEn : step.titleEs;
const goal = isEn ? step.goalEn : step.goalEs;
const body = isEn ? step.bodyEn : step.bodyEs;
const challenge = isEn ? step.challengeEn : step.challengeEs;
const tip = isEn ? step.tipEn : step.tipEs;

function formatBody(text: string): string {
	return text
		.split('\n\n')
		.map((p) => `<p>${p.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2">$1</a>')}</p>`)
		.join('');
}
---

<article class="skill-step" data-skill-step data-progress-key={progressKey}>
	<nav class="skill-step__crumb" aria-label="Breadcrumb">
		<a href={isEn ? '/en/tutoriales/guias/' : '/tutoriales/guias/'}>
			{isEn ? 'Guides' : 'Guias'}
		</a>
		<span aria-hidden="true"> / </span>
		<a href={skillSeriesHref(seriesId, locale)}>{isEn ? series.titleEn : series.titleEs}</a>
	</nav>

	<p class="skill-step__unit">
		{isEn ? `Step ${index + 1} of ${total}` : `Paso ${index + 1} de ${total}`}
	</p>

	<h1 class="skill-step__title">{title}</h1>

	{
		goal && (
			<div class="skill-step__goal">
				<p class="skill-step__goal-label">{isEn ? 'Goal' : 'Objetivo'}</p>
				<p>{goal}</p>
			</div>
		)
	}

	<div class="skill-step__body" set:html={formatBody(body)} />

	{
		step.code && (
			<pre class="skill-step__code">
				<code>{step.code}</code>
			</pre>
		)
	}

	{
		challenge && (
			<aside class="skill-step__challenge">
				<p class="skill-step__challenge-label">{isEn ? 'Try it' : 'Pruebalo'}</p>
				<p>{challenge}</p>
			</aside>
		)
	}

	{
		tip && (
			<p class="skill-step__tip">
				<strong>{isEn ? 'Tip:' : 'Consejo:'}</strong> {tip}
			</p>
		)
	}

	<label class="skill-step__done">
		<input type="checkbox" class="skill-step__done-input" data-progress-key={progressKey} />
		<span class="skill-step__done-box" aria-hidden="true" />
		<span>{isEn ? 'I completed this step' : 'Complete este paso'}</span>
	</label>

	<nav class="skill-step__pager" aria-label={isEn ? 'Tutorial navigation' : 'Navegacion del tutorial'}>
		{
			prev ? (
				<a class="skill-step__prev" href={skillStepHref(seriesId, prev.id, locale)}>
					← {isEn ? prev.titleEn : prev.titleEs}
				</a>
			) : (
				<span />
			)
		}
		{
			next ? (
				<a class="skill-step__next" href={skillStepHref(seriesId, next.id, locale)}>
					{isEn ? next.titleEn : next.titleEs} →
				</a>
			) : (
				<a class="skill-step__next skill-step__next--finish" href={skillSeriesHref(seriesId, locale)}>
					{isEn ? 'Unit complete ✓' : 'Unidad completada ✓'}
				</a>
			)
		}
	</nav>
</article>

<script>
	function initSkillSteps() {
		const STORAGE_KEY = 'aprende-pic18-skill-guides';

		function load() {
			try {
				return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
			} catch {
				return {};
			}
		}

		function save(data: Record<string, boolean>) {
			localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
			window.dispatchEvent(new CustomEvent('aprende-skill-guide-update'));
		}

		document.querySelectorAll('[data-skill-step]').forEach((root) => {
			const input = root.querySelector<HTMLInputElement>('.skill-step__done-input');
			const key = input?.getAttribute('data-progress-key');
			if (!input || !key) return;

			const saved = load();
			if (saved[key]) input.checked = true;

			input.addEventListener('change', () => {
				const data = load();
				data[key] = input.checked;
				save(data);
			});
		});
	}

	initSkillSteps();
	document.addEventListener('astro:page-load', initSkillSteps);
</script>
