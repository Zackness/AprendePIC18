---
import Figure from './Figure.astro';
import { getLabGuide } from '../data/lab-guides';

interface Props {
	practiceSlug: string;
	locale?: 'es' | 'en';
}

const { practiceSlug, locale = 'es' } = Astro.props;
const isEn = locale === 'en';
const guide = getLabGuide(practiceSlug);

if (!guide) {
	throw new Error(`Lab design content not found: ${practiceSlug}`);
}

const { design } = guide;
const pseudo = isEn ? design.pseudocodeEn : design.pseudocodeEs;
---

<section class="lab-design" aria-labelledby="lab-design-title">
	<h2 class="lab-design__title" id="lab-design-title">
		{isEn ? 'Design before coding' : 'Diseno antes del codigo'}
	</h2>
	<p class="lab-design__intro">
		{
			isEn
				? 'The official lab asks for pseudocode and a flowchart before the .ASM. Use these as a reference model for your report.'
				: 'La practica oficial pide pseudocodigo y diagrama de flujo antes del .ASM. Usa estos modelos de referencia para tu informe.'
		}
	</p>

	<details class="lab-design__block" open>
		<summary class="lab-design__summary">
			<span class="lab-design__label">{isEn ? 'Pseudocode' : 'Pseudocodigo'}</span>
		</summary>
		<pre class="lab-design__code"><code>{pseudo}</code></pre>
	</details>

	<details class="lab-design__block" open>
		<summary class="lab-design__summary">
			<span class="lab-design__label">{isEn ? 'Flowchart' : 'Diagrama de flujo'}</span>
		</summary>
		<Figure
			src={design.flowchartSrc}
			alt={isEn ? design.flowchartAltEn : design.flowchartAltEs}
			caption={isEn ? design.flowchartCaptionEn : design.flowchartCaptionEs}
			credit="Practica 1 — UNEXPO · AprendePIC18"
		/>
	</details>
</section>
