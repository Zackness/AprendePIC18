{
	"buildCommand": "npm run build",
	"outputDirectory": "dist",
	"framework": "astro",
	"rewrites": [
		{
			"source": "/api/aprende-pic18/:path*",
			"destination": "https://caleta.top/api/aprende-pic18/:path*"
		}
	],
	"headers": [
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=0, must-revalidate"
				},
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				}
			]
		}
	]
}
